<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>#(title) - Politik</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/app.css" rel="stylesheet">
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Politik</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                #if(currentUser):
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/sessions">Sessions</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/parlamentarier">Parlamentarier</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/reports">Berichte</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/sync">Sync</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/settings">Einstellungen</a>
                    </li>
                    #if(currentUser.isAdmin):
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/users">Benutzer</a>
                    </li>
                    #endif
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            #(currentUser.name)
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <form method="POST" action="/logout">
                                    <button type="submit" class="dropdown-item">Abmelden</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
                #endif
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        #import("content")
    </main>

    <footer class="container mt-5 mb-3 text-muted text-center">
        <small>Politik Server &mdash; Schweizer Parlamentsdaten</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
</body>
</html>
