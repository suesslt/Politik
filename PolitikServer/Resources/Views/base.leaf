<!DOCTYPE html>
<html lang="de" x-data="{ darkMode: localStorage.getItem('darkMode') === 'true', sidebarOpen: window.innerWidth >= 768 }" :class="darkMode ? 'dark' : ''" @resize.window="sidebarOpen = window.innerWidth >= 768">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>#(title) - Politik</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        apple: {
                            blue: '#007AFF',
                            green: '#34C759',
                            orange: '#FF9500',
                            red: '#FF3B30',
                            purple: '#AF52DE',
                            gray: '#8E8E93',
                        },
                        surface: {
                            primary: 'var(--bg-primary)',
                            secondary: 'var(--bg-secondary)',
                            tertiary: 'var(--bg-tertiary)',
                        }
                    },
                    fontSize: {
                        'title-lg': ['28px', { lineHeight: '34px', fontWeight: '700' }],
                        'title': ['22px', { lineHeight: '28px', fontWeight: '700' }],
                        'headline': ['17px', { lineHeight: '22px', fontWeight: '600' }],
                        'body': ['15px', { lineHeight: '20px', fontWeight: '400' }],
                        'caption': ['13px', { lineHeight: '18px', fontWeight: '400' }],
                        'caption2': ['11px', { lineHeight: '13px', fontWeight: '400' }],
                    },
                    width: {
                        'sidebar': '15rem',
                    }
                }
            }
        }
    </script>
    <link href="/css/app.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@9/dist/style.css" rel="stylesheet">
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <script defer src="https://unpkg.com/alpinejs@3/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/simple-datatables@9" defer></script>
</head>
<body class="bg-[var(--bg-grouped)] text-[var(--text-primary)] min-h-screen">

    <!-- Loading Bar -->
    <div id="loading-bar"></div>

    #if(currentUser):
    <!-- App Shell with Sidebar -->
    <div class="flex min-h-screen">

        <!-- Sidebar Overlay (mobile) -->
        <div x-show="sidebarOpen" @click="sidebarOpen = false" class="fixed inset-0 bg-black/30 z-30 md:hidden" x-transition:enter="transition-opacity duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition-opacity duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"></div>

        <!-- Sidebar -->
        <aside x-show="sidebarOpen" x-transition:enter="transition-sidebar" x-transition:enter-start="-translate-x-full opacity-0" x-transition:enter-end="translate-x-0 opacity-100" x-transition:leave="transition-sidebar" x-transition:leave-start="translate-x-0 opacity-100" x-transition:leave-end="-translate-x-full opacity-0" class="fixed md:sticky top-0 left-0 z-40 w-sidebar h-screen flex flex-col border-r border-[var(--separator)] vibrancy" style="background: var(--sidebar-bg);">

            <!-- Logo -->
            <div class="px-4 pt-5 pb-3">
                <a href="/" class="text-title-lg tracking-tight text-[var(--text-primary)] no-underline">Politik</a>
                <p class="text-caption text-[var(--text-secondary)] mt-0.5">Parlamentsdaten CH</p>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-3 py-2 space-y-0.5 overflow-y-auto">
                <p class="px-3 pt-4 pb-1 text-caption2 font-semibold uppercase tracking-wider text-[var(--text-tertiary)]">Daten</p>

                <a href="/sessions" class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-body text-[var(--text-primary)] hover:bg-[var(--fill-tertiary)] transition-colors">
                    <svg class="w-5 h-5 text-apple-blue shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                    Sessions
                </a>
                <a href="/parlamentarier" class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-body text-[var(--text-primary)] hover:bg-[var(--fill-tertiary)] transition-colors">
                    <svg class="w-5 h-5 text-apple-purple shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
                    Parlamentarier
                </a>
                <a href="/wortmeldungen" class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-body text-[var(--text-primary)] hover:bg-[var(--fill-tertiary)] transition-colors">
                    <svg class="w-5 h-5 text-apple-green shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
                    Wortmeldungen
                </a>
                <a href="/agenda" class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-body text-[var(--text-primary)] hover:bg-[var(--fill-tertiary)] transition-colors">
                    <svg class="w-5 h-5 text-apple-orange shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
                    Agenden
                </a>
                <a href="/reports" class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-body text-[var(--text-primary)] hover:bg-[var(--fill-tertiary)] transition-colors">
                    <svg class="w-5 h-5 text-apple-red shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                    Berichte
                </a>

                <p class="px-3 pt-5 pb-1 text-caption2 font-semibold uppercase tracking-wider text-[var(--text-tertiary)]">System</p>

                <a href="/sync" class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-body text-[var(--text-primary)] hover:bg-[var(--fill-tertiary)] transition-colors">
                    <svg class="w-5 h-5 text-apple-gray shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182"/></svg>
                    Sync
                </a>
                <a href="/settings" class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-body text-[var(--text-primary)] hover:bg-[var(--fill-tertiary)] transition-colors">
                    <svg class="w-5 h-5 text-apple-gray shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Einstellungen
                </a>

                #if(currentUser.isAdmin):
                <a href="/admin/users" class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-body text-[var(--text-primary)] hover:bg-[var(--fill-tertiary)] transition-colors">
                    <svg class="w-5 h-5 text-apple-gray shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/></svg>
                    Benutzer
                </a>
                #endif
            </nav>

            <!-- User Section -->
            <div x-data="{ userMenu: false }" class="relative px-3 py-3 border-t border-[var(--separator)]">
                <button @click="userMenu = !userMenu" @click.away="userMenu = false" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-[var(--fill-tertiary)] transition-colors text-left">
                    <div class="w-8 h-8 rounded-full bg-apple-blue flex items-center justify-center text-white text-caption font-semibold shrink-0">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-body font-medium truncate">#(currentUser.name)</p>
                        <p class="text-caption2 text-[var(--text-secondary)] truncate">#(currentUser.email)</p>
                    </div>
                    <svg class="w-4 h-4 text-[var(--text-tertiary)] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9"/></svg>
                </button>

                <!-- User Dropdown -->
                <div x-show="userMenu" x-transition x-cloak class="absolute bottom-full left-3 right-3 mb-1 bg-[var(--bg-primary)] rounded-xl shadow-lg border border-[var(--separator)] overflow-hidden z-50">
                    <button @click="darkMode = !darkMode; localStorage.setItem('darkMode', darkMode)" class="w-full flex items-center gap-3 px-4 py-2.5 text-body text-[var(--text-primary)] hover:bg-[var(--fill-tertiary)] transition-colors text-left">
                        <svg x-show="!darkMode" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/></svg>
                        <svg x-show="darkMode" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
                        <span x-text="darkMode ? 'Light Mode' : 'Dark Mode'"></span>
                    </button>
                    <div class="border-t border-[var(--separator)]"></div>
                    <form method="POST" action="/logout">
                        <button type="submit" class="w-full flex items-center gap-3 px-4 py-2.5 text-body text-apple-red hover:bg-[var(--fill-tertiary)] transition-colors text-left">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/></svg>
                            Abmelden
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 min-w-0 flex flex-col">
            <!-- Mobile Topbar -->
            <header class="md:hidden sticky top-0 z-20 px-4 py-3 border-b border-[var(--separator)] vibrancy" style="background: var(--sidebar-bg);">
                <div class="flex items-center gap-3">
                    <button @click="sidebarOpen = !sidebarOpen" class="p-1.5 rounded-lg hover:bg-[var(--fill-tertiary)] transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
                    </button>
                    <h1 class="text-headline truncate">#(title)</h1>
                </div>
            </header>

            <!-- Page Content -->
            <main class="flex-1 overflow-y-auto p-4 md:p-8">
                #import("content")
            </main>
        </div>
    </div>

    #else:
    <!-- No sidebar for unauthenticated pages -->
    <main class="min-h-screen flex items-center justify-center p-4">
        #import("content")
    </main>
    #endif

    <script src="/js/app.js"></script>
    <script>
        // Highlight active nav link
        document.querySelectorAll('.nav-link').forEach(link => {
            const href = link.getAttribute('href');
            const path = window.location.pathname;
            if (href === path || (href !== '/' && path.startsWith(href))) {
                link.classList.add('nav-item-active');
            }
        });
    </script>
</body>
</html>
